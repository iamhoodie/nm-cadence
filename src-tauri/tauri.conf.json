{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SideEye",
  "version": "0.1.4",
  "identifier": "com.cadence.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SideEye",
        "width": 1200,
        "height": 800,
        "minWidth": 920,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGNzk4QjFDMjM1QzJFNTgKUldSWUxsd2pISXQ1Nzc0eVpMamsrS3VuOVJaWUVPQjlXMlg5aHRaNEZGN0ZXM0oxbDhFMlFJZUcK",
      "endpoints": [
        "https://github.com/iamhoodie/nm-cadence/releases/latest/download/latest.json"
      ]
    }
  }
}
